{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Command",
  "type": "object",
  "required": ["id", "name", "sensitive", "status"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "sensitive": { "type": "boolean" },
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "running", "completed", "failed"]
    },
    "argv": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
