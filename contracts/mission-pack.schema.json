{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MissionPack",
  "type": "object",
  "required": ["id", "version", "missions"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "missions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
